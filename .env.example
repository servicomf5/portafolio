# Environment Variables for Portafolio Django

# Django
DEBUG=False
DJANGO_SECRET_KEY=tu-secret-key-aqui-cambiar-en-produccion
ALLOWED_HOSTS=localhost,127.0.0.1,portafolio.servicomf5.cl

# Database (PostgreSQL)
DB_NAME=portafolio_db
DB_USER=portafolio_user
DB_PASSWORD=tu-password-seguro
DB_HOST=localhost
DB_PORT=5432

# Email (SMTP)
# Cambiar EMAIL_BACKEND a console en desarrollo
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=127.0.0.1
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
DEFAULT_FROM_EMAIL=noreply@portafolio.servicomf5.cl

# Contact form
CONTACT_EMAIL=tu-email@gmail.com

# Production URL
PRODUCTION_URL=https://portafolio.servicomf5.cl
