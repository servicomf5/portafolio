# Environment Variables for Portafolio Django

# Django
DEBUG=True
SECRET_KEY=tu-secret-key-aqui-cambiar-en-produccion
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=portafolio_db
DB_USER=portafolio_user
DB_PASSWORD=tu-password-seguro
DB_HOST=localhost
DB_PORT=5432

# Email (Development - Console backend)
# Cambiar a SMTP en producción
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password

# Production URL
PRODUCTION_URL=https://portafolio.servicomf5.cl
